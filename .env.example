# =====================================
# MiroFish -> local OAuth bridge (default)
# =====================================
LLM_API_KEY=local-oauth-bridge
LLM_BASE_URL=http://127.0.0.1:8787/v1
LLM_MODEL_NAME=gpt-5.1-codex-mini
ZEP_API_KEY=YOUR_ZEP_API_KEY_HERE
GRAPH_STUCK_RECOVERY_SECONDS=30
REPORT_AGENT_MIN_TOOL_CALLS=1

# =====================================
# Bridge provider selection (shell env)
# export before running ./scripts/run-all.sh
# =====================================
# BRIDGE_PROVIDER=codex
# CODEX_MODEL=gpt-5.1-codex-mini
#
# Experimental Gemini local OAuth/provider mode:
# BRIDGE_PROVIDER=gemini
# LLM_MODEL_NAME=gemini:gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-flash
#
# Claude OAuth is intentionally NOT exposed in this public build.

# =====================================
# Optional direct OpenAI-compatible API example
# Uncomment and replace if you do NOT use the local bridge
# =====================================
# LLM_API_KEY=YOUR_OPENAI_API_KEY_HERE
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL_NAME=gpt-4o-mini

# =====================================
# Dashboard / public queue (Vercel + worker)
# =====================================
# Set these only for the Vercel dashboard app and the local queue worker
# DASHBOARD_ADMIN_PASSWORD=GENERATE_A_STRONG_PASSWORD
# GITHUB_TOKEN=YOUR_GITHUB_TOKEN_HERE
# GITHUB_OWNER=YOUR_GITHUB_OWNER
# GITHUB_REPO=mirofish-codex-oauth-allinone
# DASHBOARD_BRANCH=dashboard-data
# MIROFISH_BACKEND_BASE_URL=http://127.0.0.1:5001
# DASHBOARD_MAX_ROUNDS=16
# DASHBOARD_SIMULATION_PLATFORM=parallel
